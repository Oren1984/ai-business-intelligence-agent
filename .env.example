# .env.example — NeuroOps Insight Engine
# Copy to .env and configure as needed.
# Demo mode works out-of-the-box with no external services required.

# ── LLM Configuration ────────────────────────────────────────────────────────
# Options: demo | openai | ollama
LLM_PROVIDER=demo

# Model name (used when provider is openai or ollama)
LLM_MODEL=gpt-4.1-mini

# ── OpenAI (required if LLM_PROVIDER=openai) ─────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Ollama (required if LLM_PROVIDER=ollama) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── n8n Automation ────────────────────────────────────────────────────────────
# Set N8N_ENABLED=true and provide the webhook URL to enable live delivery.
# Example URL (when running n8n via Docker): http://localhost:5678/webhook/ai-bi-summary
N8N_ENABLED=false
N8N_WEBHOOK_URL=
